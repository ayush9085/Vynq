# Docker Environment Configuration
# Copy to .env and customize for your environment

# MongoDB Credentials (used by docker-compose)
MONGO_USER=admin
MONGO_PASSWORD=admin

# Backend Configuration
DEBUG=False
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-change-this-in-production-12345678
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (handled by docker-compose, but can override if needed)
# DATABASE_URL=mongodb://admin:admin@mongodb:27017/vynk?authSource=admin

# CORS Configuration
CORS_ORIGINS=*

# Frontend URL
FRONTEND_URL=http://localhost
