# Railway Environment Variables Template
# Copy these to Railway Dashboard → Variables

# Backend Database
MONGODB_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/vynk

# Python
PYTHONUNBUFFERED=1

# Environment
ENVIRONMENT=production

# Frontend API URL (for frontend deployment)
API_BASE_URL=https://vynk-backend.railway.app

# Optional: Add your custom domain
CUSTOM_DOMAIN=vynk.yourdomain.com
